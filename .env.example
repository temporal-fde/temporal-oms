# Copy this file to .env.local and fill in your values
# .env.local is gitignored

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=
TEMPORAL_TLS_ENABLED=false

# ── Third-Party API Keys ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
EASYPOST_API_KEY=
PREDICTHQ_API_KEY=
OPENAI_API_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=temporal_oms
DB_USERNAME=temporal_oms
DB_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
WAREHOUSE_CONFIG_PATH=python/config/warehouses.toml

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=temporal-oms
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317