# ── Setup ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored and loaded automatically by all Java services and
# Python workers. You do not need to set environment variables manually.
#
# For local development you only need to fill in the third-party API keys
# below — the Temporal defaults (localhost:7233) work out of the box.

# ── Temporal ──────────────────────────────────────────────────────────────────
# Defaults below connect to a local Temporal server (temporal server start-dev).
# For Temporal Cloud (Level 3+), update address and api-key per namespace.

TEMPORAL_APPS_ADDRESS=localhost:7233
TEMPORAL_APPS_NAMESPACE=apps
TEMPORAL_APPS_API_KEY=

TEMPORAL_PROCESSING_ADDRESS=localhost:7233
TEMPORAL_PROCESSING_NAMESPACE=processing
TEMPORAL_PROCESSING_API_KEY=

TEMPORAL_FULFILLMENT_ADDRESS=localhost:7233
TEMPORAL_FULFILLMENT_NAMESPACE=fulfillment
TEMPORAL_FULFILLMENT_API_KEY=

TEMPORAL_ENABLEMENTS_ADDRESS=localhost:7233
TEMPORAL_ENABLEMENTS_NAMESPACE=default
TEMPORAL_ENABLEMENTS_API_KEY=

# ── Third-Party API Keys ───────────────────────────────────────────────────────
# EASYPOST_API_KEY  — easypost.com → Dashboard → API Keys
#                     Required for: address verification, carrier rate quotes
# ANTHROPIC_API_KEY — console.anthropic.com
#                     Required for: AI shipping agent (shipping route selection)
# PREDICTHQ_API_KEY — predicthq.com
#                     Required for: location risk events (weather/event disruption)
ANTHROPIC_API_KEY=
EASYPOST_API_KEY=
PREDICTHQ_API_KEY=
OPENAI_API_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=temporal_oms
DB_USERNAME=temporal_oms
DB_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
WAREHOUSE_CONFIG_PATH=python/fulfillment/config/warehouses.toml

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=temporal-oms
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317