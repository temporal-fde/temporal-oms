# Local Development Environment Secrets Override
#
# Instructions:
# 1. Copy this file: cp config/environments/local.secret.yaml.template config/environments/local.secret.yaml
# 2. Fill in overrides for your local development environment
# 3. The .secret.yaml file is git-ignored and should NEVER be committed
#
# Use this to override component secrets for local development without modifying shared templates
# Example: Use different API keys for local vs dev environment

local:
  # Set to true to enable debug logging in all services
  debug: false

  # API Keys for testing (can be test/fake keys for local development)
  webhookApiKey: "local-webhook-key-test"
  webhookSecret: "local-webhook-secret-test"

  # Optional: Override payment provider keys for local testing
  # stripeTestKey: "sk_test_LOCAL"
  # stripeWebhookSecret: "whsec_LOCAL"

  # Optional: Override LLM keys for local testing
  # openaiApiKey: "sk-test-LOCAL"
  # anthropicApiKey: "sk-ant-test-LOCAL"
