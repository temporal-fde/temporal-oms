flowchart TB
  Fulfillment["fulfillment.Order<br/>deterministic business workflow"]
  Nexus["Nexus operation<br/>recommendShippingOption"]
  Agent["ShippingAgent workflow<br/>WorkflowID: customer_id"]
  Cache{"cache hit?"}
  Prompt["build_system_prompt<br/>LocalActivity"]
  Claude["call_llm<br/>Claude"]
  Finalize["finalize_recommendation<br/>structured tool output"]
