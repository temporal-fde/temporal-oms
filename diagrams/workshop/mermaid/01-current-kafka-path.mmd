flowchart LR
  subgraph Apps["apps namespace"]
    AppsOrder["apps.Order"]
  end

  subgraph Processing["processing namespace"]
    ProcessingOrder["processing.Order"]
    Fulfillments["Fulfillments.fulfillOrder()<br/>activity"]
